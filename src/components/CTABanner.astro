---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { lang, title, subtitle, ctaText, ctaHref } = Astro.props;
const T = t(lang);
const base = `/${lang}`;

const resolvedTitle = title ?? T.ctaBanner.title;
const resolvedSubtitle = subtitle ?? T.ctaBanner.subtitle;
const resolvedCta = ctaText ?? T.ctaBanner.cta;
const resolvedHref = ctaHref ?? `${base}/iletisim`;
---

<section class="cta-banner">
  <div class="container">
    <div class="cta-inner reveal">
      <h2 class="cta-title">{resolvedTitle}</h2>
      <p class="cta-subtitle">{resolvedSubtitle}</p>
      <a href={resolvedHref} class="btn btn-primary cta-btn">{resolvedCta}</a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background-color: #0e0e0e;
    border-top: 1px solid var(--color-border);
    padding: var(--section-gap) 0;
  }

  .cta-inner { max-width: 700px; }

  .cta-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .cta-subtitle {
    color: var(--color-muted);
    font-size: 1.1rem;
    font-weight: 300;
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 3rem;
  }

  .cta-btn {
    padding: 1.25rem 3rem;
    font-size: 0.85rem;
  }
</style>
