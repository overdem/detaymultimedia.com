---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, type Lang } from '../../i18n';

const lang: Lang = 'tr';
const T = t(lang);
const base = `/${lang}`;
---

<BaseLayout lang={lang} title={T.references.metaTitle} description={T.references.metaDesc}>

  <!-- BÖLÜM 1 — Hero -->
  <section class="ref-hero grid-bg">
    <div class="container">
      <span class="section-label fade-in">Referanslar</span>
      <h1 class="ref-title fade-in">
        50+ Kurumsal Proje.<br />
        Detaylar görüşmede.
      </h1>
      <p class="ref-sub fade-in">
        1999'dan bu yana Shell, Procter &amp; Gamble, Bayer,
        Yeni İlaç, Efes Pilsen ve Anadolu Motor dahil
        Türkiye'nin önde gelen kurumlarıyla çalıştık.
        Otomasyon projelerimiz devam ediyor.
        Referans detaylarını ve vaka çalışmalarını
        30 dakikalık ücretsiz görüşmemizde paylaşıyoruz.
      </p>
      <a href={`${base}/iletisim`} class="btn btn-primary fade-in">Demo Randevusu Al →</a>
    </div>
  </section>

  <!-- BÖLÜM 2 — İstatistik Bar -->
  <section class="stats-section">
    <div class="container stats-grid">
      <div class="stat-item fade-in">
        <span class="stat-num">27</span>
        <span class="stat-label">Yıllık Deneyim</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in" style="--delay:60ms">
        <span class="stat-num">50+</span>
        <span class="stat-label">Kurumsal Proje</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in" style="--delay:120ms">
        <span class="stat-num">8</span>
        <span class="stat-label">Aktif Sektör</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in" style="--delay:180ms">
        <span class="stat-num">6</span>
        <span class="stat-label">Referans Marka</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .ref-hero {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(3.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--color-border);
  }

  .ref-title {
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: 1.1;
    margin: 1rem 0 1.5rem;
    max-width: 600px;
  }

  .ref-sub {
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 2rem;
  }

  /* Stats */
  .stats-section {
    background-color: var(--color-bg-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 0;
  }

  .stats-grid {
    display: flex;
    align-items: stretch;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2.5rem 3rem;
    flex: 1;
    animation-delay: var(--delay, 0ms);
  }

  .stat-num {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    font-family: var(--font-body);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .stat-divider {
    width: 1px;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .stats-grid { flex-wrap: wrap; }
    .stat-item { flex: 1 1 40%; padding: 1.75rem 2rem; }
    .stat-divider { display: none; }
    .stats-grid .stat-item:nth-child(1),
    .stats-grid .stat-item:nth-child(2) { border-bottom: 1px solid var(--color-border); }
    .stats-grid .stat-item:nth-child(odd) { border-right: 1px solid var(--color-border); }
  }

  @media (max-width: 640px) {
    .stats-grid { flex-direction: column; flex-wrap: nowrap; }
    .stat-item { flex: none; width: 100%; padding: 1.25rem 1.5rem; border-right: none !important; border-bottom: 1px solid var(--color-border); }
    .stat-item:last-child { border-bottom: none; }
  }
</style>
