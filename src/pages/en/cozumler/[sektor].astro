---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { t, type Lang } from '../../../i18n';

export function getStaticPaths() {
  const lang: Lang = 'en';
  const T = t(lang);
  return T.sectors.map((s) => ({
    params: { sektor: s.slug },
    props: { sector: s, lang },
  }));
}

const { sector, lang } = Astro.props as { sector: ReturnType<typeof t>['sectors'][0]; lang: Lang };
const T = t(lang);
const base = `/${lang}`;

const technologies = ['Make', 'n8n', 'Claude API', 'Supabase', 'Zapier'];
---

<BaseLayout
  lang={lang}
  title={`${sector.name} ${T.sectorPage.label}`}
  description={sector.metaDescription}
>

  <section class="sector-hero grid-bg">
    <div class="container">
      <span class="section-label">{sector.name} {T.sectorPage.label}</span>
      <h1 class="sector-hero-title">{sector.headline}</h1>
      <p class="sector-hero-sub">{sector.subline}</p>
      <a href={`${base}/iletisim?sektor=${sector.slug}`} class="btn btn-primary">
        {sector.name} — {T.sectorPage.ctaDemo}
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section-label">{T.sectorPage.problemsLabel}</span>
      <h2 class="sector-section-title">{sector.name}: {T.sectorPage.problemsTitle}</h2>
      <ul class="problem-list">
        {sector.problems.map((p) => (
          <li class="problem-item fade-in">
            <span class="problem-dash" aria-hidden="true">—</span>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="section-label">{T.sectorPage.solutionLabel}</span>
      <h2 class="sector-section-title">{T.sectorPage.solutionTitle}</h2>
      <p class="sector-section-sub">{T.sectorPage.solutionSub}</p>
      <div class="solution-table">
        <div class="solution-header">
          <span>{T.sectorPage.problemCol}</span>
          <span>{T.sectorPage.outcomeCol}</span>
        </div>
        {sector.solutions.map((s) => (
          <div class="solution-row fade-in">
            <div class="solution-cell problem-cell">
              <span class="solution-badge">{T.sectorPage.problemBadge}</span>
              {s.problem}
            </div>
            <div class="solution-cell outcome-cell">
              <span class="solution-badge outcome">{T.sectorPage.outcomeBadge}</span>
              {s.outcome}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section-label">{T.sectorPage.techLabel}</span>
      <h2 class="sector-section-title">{T.sectorPage.techTitle}</h2>
      <p class="sector-section-sub">{T.sectorPage.techSub}</p>
      <div class="tech-bar">
        {technologies.map((tech) => <span class="tech-pill">{tech}</span>)}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="section-label">{T.sectorPage.referencesLabel}</span>
      <h2 class="sector-section-title">{sector.name} — {T.sectorPage.referencesTitle}</h2>
      <div class="no-case fade-in">
        <p class="no-case-text">{T.sectorPage.noCaseText}</p>
        <a href={`${base}/iletisim?sektor=${sector.slug}`} class="btn btn-outline">
          {T.sectorPage.noCaseCta}
        </a>
      </div>
    </div>
  </section>

  <CTABanner
    lang={lang}
    title={`${sector.name} ${T.sectorPage.ctaSuffix}`}
    subtitle={T.sectorPage.ctaSubtitle}
    ctaText={T.sectorPage.ctaBtn}
    ctaHref={`${base}/iletisim?sektor=${sector.slug}`}
  />

</BaseLayout>

<style>
  .sector-hero { padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem); border-bottom: 1px solid var(--color-border); }
  .sector-hero-title { font-size: var(--text-h1); font-weight: 700; max-width: 720px; margin: 0.75rem 0 1rem; line-height: 1.1; }
  .sector-hero-sub { color: var(--color-muted); max-width: 560px; margin-bottom: 2rem; font-size: 1.05rem; line-height: 1.65; }

  .sector-section-title { font-size: var(--text-h2); margin: 0.5rem 0 0.75rem; max-width: 600px; }
  .sector-section-sub { color: var(--color-muted); margin-bottom: 2.5rem; max-width: 540px; line-height: 1.65; }

  .problem-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-top: 2rem; }
  .problem-item { display: flex; gap: 0.75rem; align-items: flex-start; padding: 1.25rem 1.5rem; background-color: var(--color-bg-3); border: 1px solid var(--color-border); border-radius: 4px; font-size: var(--text-small); line-height: 1.6; color: var(--color-muted); transition: border-color 200ms ease-out; }
  .problem-item:hover { border-color: rgba(232, 150, 31, 0.3); }
  .problem-dash { color: var(--color-accent); font-weight: 700; flex-shrink: 0; }

  .solution-table { margin-top: 2rem; border: 1px solid var(--color-border); border-radius: 4px; overflow: hidden; }
  .solution-header { display: grid; grid-template-columns: 1fr 1fr; background-color: var(--color-bg-3); border-bottom: 1px solid var(--color-border); padding: 0.75rem 1.5rem; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-subtle); }
  .solution-row { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--color-border); transition: background-color 200ms ease-out; }
  .solution-row:last-child { border-bottom: none; }
  .solution-row:hover { background-color: rgba(255,255,255,0.02); }
  .solution-cell { padding: 1.25rem 1.5rem; font-size: var(--text-small); line-height: 1.55; }
  .problem-cell { border-right: 1px solid var(--color-border); color: var(--color-muted); }
  .outcome-cell { color: var(--color-text); }
  .solution-badge { display: block; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.35rem; }
  .problem-cell .solution-badge { color: var(--color-subtle); }
  .outcome-cell .solution-badge { color: var(--color-accent); }

  .tech-bar { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
  .tech-pill { font-family: var(--font-mono); font-size: var(--text-small); color: var(--color-muted); background-color: var(--color-bg-3); border: 1px solid var(--color-border); padding: 0.4rem 1rem; border-radius: 2px; }

  .no-case { margin-top: 2rem; padding: 3rem; border: 1px dashed var(--color-border); border-radius: 4px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .no-case-text { color: var(--color-muted); font-size: var(--text-small); }

  @media (max-width: 640px) {
    .solution-header { grid-template-columns: 1fr; }
    .solution-header span:last-child { display: none; }
    .solution-row { grid-template-columns: 1fr; }
    .problem-cell { border-right: none; border-bottom: 1px solid var(--color-border); }
  }
</style>
