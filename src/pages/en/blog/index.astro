---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'en';

const posts = [
  { slug: 'logistics-automation', sector: 'Logistics', type: 'seo', title: 'Process Automation in Logistics Companies: Why It\'s Become Unavoidable', summary: '70% of logistics companies in Turkey still update shipments by phone. Why does this need to change?', readTime: '6 min' },
  { slug: 'logistics-guide', sector: 'Logistics', type: 'rehber', title: 'Workflow Automation in Logistics Businesses: Step-by-Step Implementation Guide', summary: 'From shipment tracking to invoicing, driver reports to customer notifications — the complete automation map for logistics.', readTime: '12 min' },
  { slug: 'manufacturing-automation', sector: 'Manufacturing', type: 'seo', title: 'Process Automation in Manufacturing Companies: Why It\'s Become Unavoidable', summary: '80% of data entry errors in manufacturing come from manual processes. What\'s the alternative?', readTime: '6 min' },
  { slug: 'manufacturing-guide', sector: 'Manufacturing', type: 'rehber', title: 'Workflow Automation in Manufacturing & Supply Businesses: Implementation Guide', summary: 'From order tracking to inventory management, supplier communication to reporting — the full automation map for manufacturing.', readTime: '11 min' },
  { slug: 'legal-automation', sector: 'Legal', type: 'seo', title: 'Process Automation in Law Firms: Why It\'s Become Unavoidable', summary: '35% of lawyers\' time goes to administrative tasks. Automation changes this.', readTime: '6 min' },
  { slug: 'legal-guide', sector: 'Legal', type: 'rehber', title: 'Workflow Automation in Law Firms: Step-by-Step Implementation Guide', summary: 'From contract tracking to client notifications, hearing reminders to document management — the complete guide.', readTime: '12 min' },
  { slug: 'retail-automation', sector: 'Retail', type: 'seo', title: 'E-Commerce Operations Automation: Why It\'s Become Unavoidable', summary: '60% of customer service queries in e-commerce are order status questions. Automation ends this.', readTime: '6 min' },
  { slug: 'retail-guide', sector: 'Retail', type: 'rehber', title: 'Workflow Automation in Retail & E-Commerce Businesses: Implementation Guide', summary: 'From inventory sync to order management, customer notifications and return processes — the complete guide.', readTime: '11 min' },
  { slug: 'healthcare-automation', sector: 'Healthcare', type: 'seo', title: 'Clinic Appointment Automation: Why It\'s Become Unavoidable', summary: 'A 30% no-show rate in appointments without reminders. What does automation mean for clinics?', readTime: '6 min' },
  { slug: 'healthcare-guide', sector: 'Healthcare', type: 'rehber', title: 'Workflow Automation in Healthcare Institutions: Step-by-Step Implementation Guide', summary: 'From appointment management to patient communication, insurance processes to reporting — the healthcare automation guide.', readTime: '12 min' },
  { slug: 'realestate-automation', sector: 'Real Estate', type: 'seo', title: 'Real Estate Process Automation: Why It\'s Become Unavoidable', summary: 'Real estate agents spend 45% of their time on administrative tasks. How does change begin?', readTime: '6 min' },
  { slug: 'realestate-guide', sector: 'Real Estate', type: 'rehber', title: 'Workflow Automation in Real Estate Businesses: Implementation Guide', summary: 'From listing management to client tracking, viewing appointments to contract processes — the complete guide.', readTime: '11 min' },
  { slug: 'hospitality-automation', sector: 'Hospitality', type: 'seo', title: 'Hotel Operations Automation: Why It\'s Become Unavoidable', summary: 'Check-in/check-out processes in hotels average 12 minutes. How does automation reduce this?', readTime: '6 min' },
  { slug: 'hospitality-guide', sector: 'Hospitality', type: 'rehber', title: 'Workflow Automation in Hospitality Businesses: Implementation Guide', summary: 'From reservation management to guest communication, housekeeping coordination to reporting — the complete guide.', readTime: '12 min' },
  { slug: 'education-automation', sector: 'Education', type: 'seo', title: 'Process Automation in Educational Institutions: Why It\'s Become Unavoidable', summary: '50% of administrative staff time in private schools goes to manual notifications and tracking. What\'s the solution?', readTime: '6 min' },
  { slug: 'education-guide', sector: 'Education', type: 'rehber', title: 'Workflow Automation in Educational Institutions: Step-by-Step Implementation Guide', summary: 'From enrollment processes to attendance tracking, parent notifications to payment reminders — the complete guide.', readTime: '11 min' },
];

const sectors = ['All', 'Logistics', 'Manufacturing', 'Legal', 'Retail', 'Healthcare', 'Real Estate', 'Hospitality', 'Education'];
---

<BaseLayout
  lang={lang}
  title="Blog & Guides — Detay Multimedia"
  description="Industry-specific business automation guides. Practical content for logistics, manufacturing, legal, retail, and more."
>

  <section class="blog-hero grid-bg">
    <div class="container">
      <span class="section-label">Blog & Guides</span>
      <h1 class="blog-title">Everything you need to know<br />about automation</h1>
      <p class="blog-sub">Industry-specific guides, practical content, real-world scenarios.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="filter-bar" role="tablist" aria-label="Sector filter">
        {sectors.map(s => (
          <button
            class={`filter-btn${s === 'All' ? ' active' : ''}`}
            data-filter={s === 'All' ? 'all' : s}
            role="tab"
            aria-selected={s === 'All' ? 'true' : 'false'}
          >
            {s}
          </button>
        ))}
      </div>

      <div class="posts-grid" id="posts-grid">
        {posts.map((post, i) => (
          <a
            href={`/en/blog/${post.slug}`}
            class="post-card card fade-in"
            data-sector={post.sector}
            style={`--delay:${(i % 8) * 60}ms`}
          >
            <div class="post-card-top">
              <span class="post-sector-tag">{post.sector}</span>
              <span class={`post-type-tag ${post.type}`}>
                {post.type === 'seo' ? 'Automation Guide' : 'Deep Dive'}
              </span>
            </div>
            <h2 class="post-card-title">{post.title}</h2>
            <p class="post-card-summary">{post.summary}</p>
            <div class="post-card-footer">
              <span class="post-read-time">{post.readTime}</span>
              <span class="post-cta">Read More →</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .blog-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 5vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-title {
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: 1.1;
    margin: 1rem 0 1rem;
    max-width: 600px;
  }

  .blog-sub {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 480px;
    line-height: 1.65;
  }

  /* Filter */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 6px 14px;
    cursor: pointer;
    transition: all 200ms ease-out;
    min-height: 32px;
  }

  .filter-btn:hover {
    border-color: rgba(232, 150, 31, 0.4);
    color: var(--color-text);
  }

  .filter-btn.active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #0F0F0E;
  }

  /* Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    animation-delay: var(--delay, 0ms);
    transition: border-color 200ms ease-out, transform 200ms ease-out;
  }

  .post-card:hover { transform: translateY(-2px); }

  .post-card[hidden] { display: none; }

  .post-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-sector-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    border-left: 2px solid var(--color-accent);
    padding-left: 6px;
  }

  .post-type-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 2px;
    border: 1px solid var(--color-border);
    color: var(--color-subtle);
  }

  .post-type-tag.rehber {
    border-color: rgba(232, 150, 31, 0.25);
    color: var(--color-muted);
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
  }

  .post-card-summary {
    font-size: var(--text-small);
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .post-read-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-subtle);
    letter-spacing: 0.06em;
  }

  .post-cta {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .filter-bar { gap: 0.4rem; }
    .filter-btn { font-size: 10px; padding: 5px 10px; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const filter = btn.dataset.filter ?? 'all';
      cards.forEach(card => {
        const sector = card.dataset.sector ?? '';
        if (filter === 'all' || sector === filter) {
          card.removeAttribute('hidden');
        } else {
          card.setAttribute('hidden', '');
        }
      });
    });
  });
</script>
