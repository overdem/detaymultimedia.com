---
import BaseLayout from './BaseLayout.astro';
import BlogCTA from '../components/BlogCTA.astro';

interface Props {
  title: string;
  description: string;
  sector: string;
  sectorSlug: string;
  readTime: string;
  publishDate: string;
  type: 'seo' | 'rehber';
  relatedPosts?: Array<{ title: string; href: string; type: 'seo' | 'rehber' }>;
  lang?: 'tr' | 'en';
}

const {
  title,
  description,
  sector,
  sectorSlug,
  readTime,
  publishDate,
  type,
  relatedPosts = [],
  lang = 'tr',
} = Astro.props;
const typeLabel = lang === 'en'
  ? (type === 'seo' ? 'Automation Guide' : 'Practical Guide')
  : (type === 'seo' ? 'Otomasyon Rehberi' : 'Pratik Rehber');
const breadcrumbLabel = lang === 'en'
  ? (type === 'seo' ? `${sector} Automation` : `${sector} Process Guide`)
  : (type === 'seo' ? `${sector} Otomasyonu` : `${sector} Süreçler Rehberi`);

const canonicalURL = Astro.url.href;
const fullTitle = `${title} — Detay Multimedya Blog`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Detay Multimedya",
    "url": "https://detaymultimedia.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Detay Multimedya",
    "url": "https://detaymultimedia.com"
  },
  "datePublished": publishDate,
  "inLanguage": lang === 'tr' ? 'tr-TR' : 'en-US',
  "url": canonicalURL,
  "articleSection": sector,
  "keywords": lang === 'tr'
    ? `${sector} otomasyonu, iş akışı otomasyonu, süreç otomasyonu`
    : `${sector} automation, workflow automation, process automation`,
};
---

<BaseLayout
  lang={lang}
  title={fullTitle}
  description={description}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:section" content={sector} />
    <meta property="article:published_time" content={publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="blog-hero grid-bg">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`/${lang}`}>{lang === 'en' ? 'Home' : 'Ana Sayfa'}</a>
        <span class="bc-sep">›</span>
        <a href={`/${lang}/blog`}>Blog</a>
        <span class="bc-sep">›</span>
        <span>{breadcrumbLabel}</span>
      </nav>
      <div class="post-meta">
        <span class="section-label">{sector} · {typeLabel}</span>
        <div class="post-meta-row">
          <span class="meta-item">{publishDate}</span>
          <span class="meta-sep">·</span>
          <span class="meta-item">{readTime} {lang === 'en' ? 'read' : 'okuma'}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="blog-layout container">

    <article class="blog-content">
      <slot />
      <BlogCTA sector={sector} sectorSlug={sectorSlug} variant="footer" />
    </article>

    <aside class="blog-sidebar">
      <div class="sidebar-sticky">

        <div class="sidebar-cta card">
          <span class="section-label" style="font-size:10px;margin-bottom:0.5rem">{sector} · {lang === 'en' ? 'Free Analysis' : 'Ücretsiz Analiz'}</span>
          <p class="sidebar-cta-text">{lang === 'en' ? `Get a custom process analysis for ${sector}. Start in 30 minutes.` : `${sector} sektörü için özel süreç analizi alın. 30 dakikada başlayın.`}</p>
          <a href={`/${lang}/iletisim?sektor=${sectorSlug}`} class="btn btn-primary sidebar-btn">
            {lang === 'en' ? 'Schedule a Demo →' : 'Demo Randevusu Al →'}
          </a>
        </div>

        {relatedPosts.length > 0 && (
          <div class="sidebar-related">
            <span class="sidebar-related-title">{lang === 'en' ? 'Related Content' : 'İlgili İçerikler'}</span>
            {relatedPosts.map(post => (
              <a href={post.href} class="related-link">
                <span class="related-type">{lang === 'en' ? (post.type === 'seo' ? 'Automation Guide' : 'Deep Dive') : (post.type === 'seo' ? 'SEO Rehberi' : 'Derinlemesine')}</span>
                <span class="related-title">{post.title}</span>
              </a>
            ))}
          </div>
        )}

        <a href={`/${lang}/cozumler/${sectorSlug}`} class="sidebar-sector-link">
          {lang === 'en' ? `Explore our ${sector} solutions →` : `${sector} çözümlerimizi inceleyin →`}
        </a>

      </div>
    </aside>

  </div>

</BaseLayout>

<style>
  .blog-hero {
    padding: clamp(4rem, 8vw, 6rem) 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 12px;
    color: var(--color-subtle);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-muted); transition: color 200ms; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .bc-sep { color: var(--color-subtle); }

  .post-meta { display: flex; flex-direction: column; gap: 0.75rem; }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-subtle);
  }

  .meta-sep { color: var(--color-subtle); }

  /* Layout */
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    padding-top: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    align-items: start;
  }

  /* Article typography */
  .blog-content :global(h1) {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 1.5rem;
    color: var(--color-text);
    max-width: 680px;
  }

  .blog-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 2.75rem 0 1rem;
    color: var(--color-text);
    max-width: 680px;
  }

  .blog-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.6rem;
    color: var(--color-text);
  }

  .blog-content :global(p) {
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    max-width: 680px;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 0.75rem 0 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-width: 660px;
  }

  .blog-content :global(li) {
    font-size: 1.0625rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .blog-content :global(ul li) { list-style: disc; }
  .blog-content :global(ol li) { list-style: decimal; }

  .blog-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Tables */
  .blog-content :global(table) {
    width: 100%;
    max-width: 680px;
    border-collapse: collapse;
    margin: 1.5rem 0 2rem;
    font-size: var(--text-small);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .blog-content :global(th) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-subtle);
    padding: 0.75rem 1rem;
    text-align: left;
    background-color: var(--color-bg-3);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-content :global(td) {
    padding: 0.75rem 1rem;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    line-height: 1.5;
  }

  .blog-content :global(tr:last-child td) { border-bottom: none; }
  .blog-content :global(tr:hover td) { background-color: rgba(255,255,255,0.02); }

  /* CTA inline box */
  .blog-content :global(.cta-box) {
    border-left: 4px solid var(--color-accent);
    background-color: var(--color-bg-3);
    border-radius: 0 4px 4px 0;
    padding: 1.5rem 1.75rem;
    margin: 2.5rem 0;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .blog-content :global(.cta-box p) {
    color: var(--color-text) !important;
    font-weight: 500;
    margin-bottom: 0 !important;
  }

  /* Stat highlight */
  .blog-content :global(.stat-highlight) {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-accent);
    background-color: rgba(232, 150, 31, 0.08);
    border: 1px solid rgba(232, 150, 31, 0.2);
    border-radius: 2px;
    padding: 2px 8px;
    margin: 0 2px;
  }

  /* Step list */
  .blog-content :global(.steps-list) {
    list-style: none !important;
    margin-left: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 680px;
  }

  .blog-content :global(.steps-list li) {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 1rem;
    align-items: start;
  }

  .blog-content :global(.step-num) {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
    padding-top: 0.1rem;
  }

  /* Priority matrix */
  .blog-content :global(.matrix) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    max-width: 680px;
    margin: 1.5rem 0;
  }

  .blog-content :global(.matrix-cell) {
    background-color: var(--color-bg-3);
    padding: 1.25rem;
  }

  .blog-content :global(.matrix-label) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    display: block;
  }

  .blog-content :global(.matrix-cell p) {
    font-size: var(--text-small) !important;
    margin-bottom: 0 !important;
  }

  .blog-content :global(.matrix-cell ul) {
    margin: 0.5rem 0 0 1rem !important;
    gap: 0.25rem !important;
  }

  .blog-content :global(.matrix-cell li) {
    font-size: var(--text-small) !important;
  }

  /* Self-assessment questions */
  .blog-content :global(.questions-list) {
    list-style: none !important;
    margin-left: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 680px;
  }

  .blog-content :global(.questions-list li) {
    padding: 1rem 1.25rem;
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    border-left: 3px solid var(--color-border);
    transition: border-color 200ms;
  }

  .blog-content :global(.questions-list li:hover) {
    border-left-color: var(--color-accent);
  }

  /* Sidebar */
  .blog-sidebar { min-width: 0; }

  .sidebar-sticky {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-cta-text {
    font-size: var(--text-small);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .sidebar-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.85rem;
    padding: 10px 16px;
  }

  .sidebar-related {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-related-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
    margin-bottom: 0.25rem;
    display: block;
  }

  .related-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background-color: var(--color-bg-3);
    transition: border-color 200ms;
  }

  .related-link:hover { border-color: rgba(232, 150, 31, 0.4); }

  .related-type {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .related-title {
    font-size: var(--text-small);
    color: var(--color-muted);
    line-height: 1.4;
  }

  .sidebar-sector-link {
    font-size: var(--text-small);
    color: var(--color-accent);
    font-weight: 600;
    display: block;
    padding: 0.5rem 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
    .blog-sidebar {
      display: none;
    }
  }
</style>
