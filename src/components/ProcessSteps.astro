---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const T = t(lang);
---

<section class="process-section">
  <div class="container">
    <div class="reveal">
      <span class="section-label">{T.home.processLabel}</span>
      <h2 class="section-heading">{T.home.processTitle}</h2>
      <p class="process-sub">{T.home.processSub}</p>
    </div>

    <div class="steps-grid">
      {T.home.steps.map((s, i) => (
        <div class="step-card reveal" style={`transition-delay:${i * 80}ms`}>
          <div class="step-top">
            <span class="step-num">{s.number}</span>
            <span class="step-duration">{s.duration}</span>
          </div>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: var(--section-gap) 0;
    background-color: var(--color-bg-2);
  }

  .section-heading {
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .process-sub {
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 300;
    margin-bottom: 3rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .step-card {
    background-color: var(--color-bg);
    padding: 2.5rem;
    transition: background-color 200ms ease-out, opacity 0.6s ease, transform 0.6s ease;
  }

  .step-card:hover { background-color: var(--color-bg-3); }

  .step-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .step-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 3.5rem;
    color: rgba(255,255,255,0.04);
    line-height: 1;
    transition: color 200ms ease-out;
  }

  .step-card:hover .step-num { color: rgba(255, 87, 8, 0.15); }

  .step-duration {
    font-family: var(--font-label);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-subtle);
    margin-top: 0.5rem;
  }

  .step-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 1rem;
    transition: color 200ms ease-out;
  }

  .step-card:hover .step-title { color: var(--color-accent); }

  .step-desc {
    color: var(--color-muted);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
