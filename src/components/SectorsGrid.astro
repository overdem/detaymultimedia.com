---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const T = t(lang);
const base = `/${lang}`;
---

<section class="sectors-section" id="cozumler">
  <div class="container">
    <div class="sectors-header reveal">
      <div>
        <span class="section-label">{T.home.sectorsLabel}</span>
        <h2 class="section-heading">{T.home.sectorsTitle}</h2>
      </div>
    </div>

    <p class="sectors-sub reveal">{T.home.sectorsSub}</p>

    <div class="sectors-grid">
      {T.sectors.map((s, i) => (
        <a
          href={`${base}/cozumler/${s.slug}`}
          class="sector-card reveal"
          style={`transition-delay:${i * 60}ms`}
        >
          <div class="sector-icon" aria-hidden="true">{s.icon}</div>
          <h3 class="sector-name">{s.name}</h3>
          <p class="sector-desc">{s.summary}</p>
          <span class="sector-link">İncele →</span>
        </a>
      ))}
    </div>

    <p class="sectors-fallback">
      {T.home.sectorsMissing}
      <a href={`${base}/iletisim`} class="fallback-link">{T.home.sectorsMissingCta}</a>
    </p>
  </div>
</section>

<style>
  .sectors-section {
    padding: var(--section-gap) 0;
  }

  .sectors-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.5rem;
  }

  .section-heading {
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.03em;
    max-width: 500px;
  }

  .sectors-sub {
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 300;
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 3rem;
  }

  .sectors-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .sector-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background-color: var(--color-bg);
    padding: 2rem;
    border: 1px solid transparent;
    transition: background-color 200ms ease-out, border-color 200ms ease-out, opacity 0.6s ease, transform 0.6s ease;
  }

  .sector-card:hover {
    background-color: var(--color-bg-2);
    border-color: var(--color-accent);
  }

  .sector-icon {
    font-size: 2rem;
    color: rgba(255,255,255,0.1);
    font-family: var(--font-label);
    line-height: 1;
    transition: color 200ms ease-out;
  }

  .sector-card:hover .sector-icon { color: var(--color-accent); }

  .sector-name {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    transition: color 200ms ease-out;
  }

  .sector-card:hover .sector-name { color: var(--color-accent); }

  .sector-desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-weight: 300;
    line-height: 1.6;
    flex: 1;
  }

  .sector-link {
    font-family: var(--font-label);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0;
    transition: opacity 200ms ease-out;
  }

  .sector-card:hover .sector-link { opacity: 1; }

  .sectors-fallback {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    padding: 1rem;
  }

  .fallback-link {
    color: var(--color-accent);
    font-weight: 600;
    margin-left: 0.25rem;
  }

  @media (max-width: 1024px) {
    .sectors-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .sectors-grid { grid-template-columns: 1fr; }
  }
</style>
