---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, type Lang } from '../../i18n';

const lang: Lang = 'en';;
const T = t(lang);
const base = `/${lang}`;

// URL'den sektor parametresi
const sectorParam = Astro.url.searchParams.get('sektor') ?? '';
const preselectedSector = T.sectors.find(s => s.slug === sectorParam);
---

<BaseLayout lang={lang} title={T.contact.metaTitle} description={T.contact.metaDesc}>

  <section class="contact-hero grid-bg">
    <div class="container">
      <span class="section-label">{T.contact.heroLabel}</span>
      <h1 class="contact-title">{T.contact.heroTitle}</h1>
      <p class="contact-sub">{T.contact.heroSub}</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">

      <div class="contact-info">
        <div class="info-block">
          <span class="section-label">Garanti</span>
          <p class="info-text">{T.contact.responseNote}</p>
        </div>
        <div class="info-block">
          <span class="section-label">E-posta</span>
          <!-- TODO: Gerçek e-posta -->
          <a href="mailto:info@detaymultimedia.com" class="info-link">info@detaymultimedia.com</a>
        </div>
        <!-- TODO: Telefon ve adres ekle -->
      </div>

      <div class="contact-form-wrap">
        <!-- Formspree veya Netlify Forms ile entegre edilecek -->
        <!-- TODO: n8n webhook bağlantısı -->
        <form
          class="contact-form"
          method="POST"
          action="https://formspree.io/f/placeholder"
          id="contact-form"
        >
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="name">{T.contact.formName}</label>
              <input
                class="form-input"
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="company">{T.contact.formCompany}</label>
              <input
                class="form-input"
                type="text"
                id="company"
                name="company"
                required
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="sector">{T.contact.formSector}</label>
              <select class="form-input form-select" id="sector" name="sector">
                <option value="">— Seçin</option>
                {T.sectors.map(s => (
                  <option value={s.slug} selected={s.slug === sectorParam}>{s.name}</option>
                ))}
                <option value="diger">Diğer</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="size">{T.contact.formSize}</label>
              <select class="form-input form-select" id="size" name="size">
                <option value="">— Seçin</option>
                {T.contact.sizes.map(s => (
                  <option value={s}>{s} çalışan</option>
                ))}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="process">{T.contact.formProcess}</label>
            <textarea
              class="form-input form-textarea"
              id="process"
              name="process"
              rows={4}
              placeholder={T.contact.formProcessPlaceholder}
            ></textarea>
          </div>

          <div class="form-group">
            <label class="form-label" for="contact">{T.contact.formPhone}</label>
            <input
              class="form-input"
              type="text"
              id="contact"
              name="contact"
              required
              autocomplete="tel"
            />
          </div>

          <button type="submit" class="btn btn-primary form-submit">
            {T.contact.formSubmit}
          </button>

          <p class="form-note">{T.contact.responseNote}</p>
        </form>

        <div class="form-success" id="form-success" aria-live="polite" hidden>
          <p>{T.contact.formSuccess}</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero {
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 5vw, 4.5rem);
    border-bottom: 1px solid var(--color-border);
  }

  .contact-title { font-size: var(--text-h1); font-weight: 700; margin: 0.75rem 0 1rem; max-width: 600px; }
  .contact-sub { color: var(--color-muted); max-width: 480px; line-height: 1.65; font-size: 1.05rem; }

  .contact-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info { display: flex; flex-direction: column; gap: 2rem; padding-top: 0.25rem; }

  .info-block { display: flex; flex-direction: column; gap: 0.5rem; }

  .info-text { font-size: var(--text-small); color: var(--color-muted); line-height: 1.55; }

  .info-link {
    font-size: var(--text-small);
    color: var(--color-muted);
    transition: color 200ms ease-out;
  }

  .info-link:hover { color: var(--color-accent); }

  .contact-form-wrap { min-width: 0; }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }

  .form-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .form-input {
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 0.85rem 1rem;
    font-size: var(--text-small);
    color: var(--color-text);
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    width: 100%;
    appearance: none;
    min-height: 44px;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(232, 150, 31, 0.12);
  }

  .form-input::placeholder { color: var(--color-subtle); }

  .form-select {
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%237A7972' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .form-textarea { resize: vertical; min-height: 100px; }

  .form-submit { align-self: flex-start; padding: 12px 28px; margin-top: 0.5rem; }

  .form-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-subtle);
  }

  .form-success {
    background-color: rgba(61, 140, 90, 0.1);
    border: 1px solid rgba(61, 140, 90, 0.3);
    border-radius: 4px;
    padding: 1.5rem;
    color: var(--color-success);
    font-size: var(--text-small);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-info { flex-direction: row; flex-wrap: wrap; }
  }

  @media (max-width: 768px) {
    .contact-layout { gap: 2rem; }
    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .form-submit { width: 100%; justify-content: center; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.hidden = true;
        if (successMsg) successMsg.hidden = false;
      }
    } catch {
      // Sunucu hatası — kullanıcıya bildir
    }
  });
</script>
