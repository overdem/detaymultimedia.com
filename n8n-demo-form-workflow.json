        "emailType": "html",
        "message": "=<html><body style=\"font-family: sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 24px;\">\n<h2 style=\"color: #E8961F; border-bottom: 2px solid #E8961F; padding-bottom: 8px;\">Yeni Demo Talebi</h2>\n\n<table style=\"width: 100%; border-collapse: collapse; margin-top: 16px;\">\n  <tr style=\"background: #f9f9f9;\">\n    <td style=\"padding: 10px 14px; font-weight: bold; width: 40%; border: 1px solid #eee;\">Ad Soyad</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.name ?? $json.name }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 14px; font-weight: bold; border: 1px solid #eee;\">Şirket</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.company ?? $json.company }}</td>\n  </tr>\n  <tr style=\"background: #f9f9f9;\">\n    <td style=\"padding: 10px 14px; font-weight: bold; border: 1px solid #eee;\">Sektör</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.sector ?? $json.sector }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 14px; font-weight: bold; border: 1px solid #eee;\">Şirket Büyüklüğü</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.size ?? $json.size }} çalışan</td>\n  </tr>\n  <tr style=\"background: #f9f9f9;\">\n    <td style=\"padding: 10px 14px; font-weight: bold; border: 1px solid #eee;\">İletişim</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.contact ?? $json.contact }}</td>\n  </tr>\n  <tr>\n    <td style=\"padding: 10px 14px; font-weight: bold; vertical-align: top; border: 1px solid #eee;\">Süreç / Not</td>\n    <td style=\"padding: 10px 14px; border: 1px solid #eee;\">{{ $json.body.process ?? $json.process }}</td>\n  </tr>\n</table>\n\n<p style=\"margin-top: 24px; font-size: 13px; color: #888;\">detaymultimedia.com üzerinden gönderildi.</p>\n</body></html>",
        "options": {}
      },
      "id": "gmail-node",
      "name": "Gmail — Bildirim Gönder",
