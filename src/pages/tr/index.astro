---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Ticker from '../../components/Ticker.astro';
import PainPoints from '../../components/PainPoints.astro';
import SectorsGrid from '../../components/SectorsGrid.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import ReferencesSection from '../../components/ReferencesSection.astro';
import CTABanner from '../../components/CTABanner.astro';
import { type Lang } from '../../i18n';

const lang: Lang = 'tr';
---

<BaseLayout lang={lang} title="__home__">
  <Hero lang={lang} />
  <Ticker />
  <PainPoints lang={lang} />
  <SectorsGrid lang={lang} />
  <ProcessSteps lang={lang} />
  <ReferencesSection lang={lang} />
  <CTABanner lang={lang} />
</BaseLayout>
