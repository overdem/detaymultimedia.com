---
import BaseLayout from './BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';

interface Solution {
  problem: string;
  outcome: string;
}

interface CaseStudy {
  company: string;
  problem: string;
  solution: string;
  result: string;
  href?: string;
}

interface Props {
  name: string;
  slug: string;
  headline: string;
  subline: string;
  problems: string[];
  solutions: Solution[];
  technologies?: string[];
  caseStudy?: CaseStudy | null;
  metaDescription?: string;
}

const {
  name,
  slug,
  headline,
  subline,
  problems,
  solutions,
  technologies = ['Make', 'n8n', 'Claude API', 'Supabase'],
  caseStudy = null,
  metaDescription,
} = Astro.props;

const description = metaDescription || `${name} sektörü için özel iş otomasyonu çözümleri. ${subline}`;
---

<BaseLayout title={`${name} Otomasyonu`} description={description}>

  <!-- HERO -->
  <section class="sector-hero grid-bg">
    <div class="container">
      <span class="section-label">{name} Otomasyonu</span>
      <h1 class="sector-hero-title">{headline}</h1>
      <p class="sector-hero-sub">{subline}</p>
      <a href={`/iletisim?sektor=${slug}`} class="btn btn-primary">
        {name} Sektörü İçin Demo Al →
      </a>
    </div>
  </section>

  <!-- SORUNLAR -->
  <section class="section">
    <div class="container">
      <span class="section-label">Tanıdık mı geliyor?</span>
      <h2 class="sector-section-title">{name} Sektöründe Gördüğümüz Sorunlar</h2>
      <ul class="problem-list">
        {problems.map(p => (
          <li class="problem-item fade-in">
            <span class="problem-icon" aria-hidden="true">—</span>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ÇÖZÜM HARİTASI -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">Otomasyon Haritası</span>
      <h2 class="sector-section-title">Sorundan Çıktıya</h2>
      <p class="sector-section-sub">
        Her manuel sürecin karşısına bir otomasyon çıktısı koyuyoruz.
      </p>
      <div class="solution-table">
        <div class="solution-header">
          <span>Mevcut Sorun</span>
          <span>Otomasyon Çıktısı</span>
        </div>
        {solutions.map(s => (
          <div class="solution-row fade-in">
            <div class="solution-problem">
              <span class="solution-badge">Sorun</span>
              {s.problem}
            </div>
            <div class="solution-outcome">
              <span class="solution-badge outcome">Çıktı</span>
              {s.outcome}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KULLANIM SENARYOSU (slot) -->
  <slot name="scenario" />

  <!-- TEKNOLOJİLER -->
  <section class="section">
    <div class="container">
      <span class="section-label">Altyapı</span>
      <h2 class="sector-section-title">Sistemi Biz Kuruyoruz, Siz Kullanıyorsunuz</h2>
      <p class="sector-section-sub">
        Hangi teknolojiyi kullandığımız değil, ne sonuç aldığınız önemli.<br />
        Ama merak edenler için:
      </p>
      <div class="tech-bar">
        {technologies.map(t => (
          <span class="tech-pill">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- REFERANSLAR -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">Referanslar</span>
      <h2 class="sector-section-title">{name} Sektöründen Vakalar</h2>
      {caseStudy ? (
        <div class="case-grid">
          <CaseStudyCard
            sector={name}
            company={caseStudy.company}
            problem={caseStudy.problem}
            solution={caseStudy.solution}
            result={caseStudy.result}
            href={caseStudy.href}
          />
        </div>
      ) : (
        <div class="no-case fade-in">
          <p class="no-case-text">
            <!-- TODO: Bu sektör için vaka çalışması eklenecek -->
            Bu sektörde yeni projeler başlatıyoruz.
          </p>
          <a href="/iletisim" class="btn btn-outline">
            İlk Referansınız Siz Olun →
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title={`${name} sektörü için özel analiz talep edin`}
    subtitle="Süreçlerinizi inceleyip size özel otomasyon haritası çıkarıyoruz. Ücretsiz."
    ctaText={`${name} Analizi Talep Et →`}
    ctaHref={`/iletisim?sektor=${slug}`}
  />

</BaseLayout>

<style>
  .sector-hero {
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(4rem, 8vw, 6rem);
    position: relative;
  }

  .sector-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .sector-hero-title {
    font-size: var(--text-h1);
    font-weight: 700;
    max-width: 720px;
    margin: 0.75rem 0 1rem;
    line-height: 1.1;
  }

  .sector-hero-sub {
    color: var(--color-muted);
    max-width: 560px;
    margin-bottom: 2rem;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .sector-section-title {
    margin: 0.5rem 0 0.75rem;
    max-width: 600px;
  }

  .sector-section-sub {
    color: var(--color-muted);
    margin-bottom: 2.5rem;
    max-width: 540px;
    line-height: 1.65;
  }

  /* Problem listesi */
  .problem-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .problem-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: var(--text-small);
    line-height: 1.6;
    color: var(--color-muted);
  }

  .problem-icon {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  /* Çözüm tablosu */
  .solution-table {
    margin-top: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .solution-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background-color: var(--color-bg-3);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .solution-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
    transition: background-color 200ms ease-out;
  }

  .solution-row:last-child {
    border-bottom: none;
  }

  .solution-row:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  .solution-problem,
  .solution-outcome {
    padding: 1.25rem 1.5rem;
    font-size: var(--text-small);
    line-height: 1.55;
  }

  .solution-problem {
    border-right: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  .solution-outcome {
    color: var(--color-text);
  }

  .solution-badge {
    display: block;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .solution-problem .solution-badge { color: var(--color-subtle); }
  .solution-outcome .solution-badge { color: var(--color-accent); }

  /* Teknoloji bar */
  .tech-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .tech-pill {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--color-muted);
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    padding: 0.4rem 1rem;
    border-radius: 2px;
  }

  /* Case grid */
  .case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 400px));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  /* No case */
  .no-case {
    margin-top: 2rem;
    padding: 3rem;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .no-case-text {
    color: var(--color-muted);
    font-size: var(--text-small);
  }

  @media (max-width: 640px) {
    .solution-header,
    .solution-row {
      grid-template-columns: 1fr;
    }

    .solution-header span:last-child { display: none; }
    .solution-problem { border-right: none; border-bottom: 1px solid var(--color-border); }
  }
</style>
