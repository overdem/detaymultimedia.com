---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;

const title = 'Müşteriler - Admin Paneli';
const description = 'Müşteri yönetimi';
---

<AdminLayout title={title} description={description}>
  <div class="customers-page">
    <div class="page-header">
      <h2>Müşteri Yönetimi</h2>
    </div>

    <div class="page-header">
      <button id="addCustomerBtn" class="btn-add">+ Yeni Müşteri Ekle</button>
    </div>

    <div id="addCustomerForm" class="add-form" style="display:none;">
      <h3>Yeni Müşteri</h3>
      <form id="newCustomerForm">
        <div class="form-row">
          <div class="form-group">
            <label>Ad Soyad</label>
            <input type="text" name="name" required placeholder="Ahmet Yılmaz" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" required placeholder="ahmet@firma.com" />
          </div>
          <div class="form-group">
            <label>Şifre</label>
            <input type="password" name="password" required placeholder="••••••••" minlength="6" />
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-save">Kaydet</button>
          <button type="button" id="cancelBtn" class="btn-cancel">İptal</button>
        </div>
        <p id="formError" class="form-error" style="display:none;"></p>
      </form>
    </div>

    <div id="customersList" class="customers-table-container">
      <p style="text-align: center; color: var(--color-muted);">Yükleniyor...</p>
    </div>
  </div>
</AdminLayout>

<style>
  .customers-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .page-header h2 {
    margin: 0;
    font-size: 1.8rem;
    color: var(--color-text);
    font-weight: 900;
  }

  .customers-table-container {
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background-color: rgba(255, 87, 8, 0.05);
    border-bottom: 1px solid var(--color-border);
  }

  th {
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  td {
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.95rem;
  }

  tbody tr:hover {
    background-color: rgba(255, 87, 8, 0.05);
  }

  .page-header:last-of-type {
    display: flex;
    justify-content: flex-end;
  }

  .btn-add {
    background-color: var(--color-accent);
    color: #fff;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 200ms;
  }

  .btn-add:hover {
    background-color: #ff6b1a;
  }

  .add-form {
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .add-form h3 {
    margin: 0 0 1rem;
    color: var(--color-text);
    font-size: 1rem;
  }

  .form-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-width: 180px;
  }

  .form-group label {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group input {
    padding: 0.6rem 0.8rem;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .btn-save {
    background-color: var(--color-accent);
    color: #fff;
    border: none;
    padding: 0.5rem 1.2rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
  }

  .btn-cancel {
    background: transparent;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .form-error {
    color: #d9a5a5;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  .btn-assign {
    background-color: var(--color-accent);
    color: #fff;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.7rem;
    text-transform: uppercase;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 200ms;
    display: inline-block;
  }

  .btn-assign:hover {
    background-color: #ff6b1a;
  }

  @media (max-width: 768px) {
    table {
      font-size: 0.85rem;
    }

    th,
    td {
      padding: 0.75rem 0.5rem;
    }
  }
</style>

<script>
  async function loadCustomers() {
    try {
      const response = await fetch('/api/admin/customers', {
        credentials: 'include',
      });

      if (!response.ok) throw new Error('Failed to fetch customers');

      const customers = await response.json();
      const customersList = document.getElementById('customersList')!;

      if (!customers.length) {
        customersList.innerHTML =
          '<p style="padding: 2rem; text-align: center; color: var(--color-muted);">Henüz müşteri eklenmemiş</p>';
        return;
      }

      let html = `
        <table>
          <thead>
            <tr>
              <th>Adı</th>
              <th>Email</th>
              <th>Kayıt Tarihi</th>
              <th>İşlemler</th>
            </tr>
          </thead>
          <tbody>
      `;

      customers.forEach((customer: any) => {
        const createdAt = new Date(customer.created_at).toLocaleDateString('tr-TR');
        html += `
          <tr>
            <td><strong>${customer.name || '-'}</strong></td>
            <td>${customer.email}</td>
            <td>${createdAt}</td>
            <td>
              <a href="/admin/customers/assign?id=${customer.id}" class="btn-assign">Demo Ata</a>
            </td>
          </tr>
        `;
      });

      html += `</tbody></table>`;
      customersList.innerHTML = html;
    } catch (err) {
      console.error('Error:', err);
      document.getElementById('customersList')!.innerHTML =
        '<p style="padding: 2rem; text-align: center; color: var(--color-error);">Müşteriler yüklenemedi</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    if (!localStorage.getItem('admin')) {
      window.location.href = '/admin/login';
      return;
    }

    loadCustomers();

    // "Yeni Müşteri Ekle" toggle
    document.getElementById('addCustomerBtn')!.addEventListener('click', () => {
      document.getElementById('addCustomerForm')!.style.display = 'block';
    });

    document.getElementById('cancelBtn')!.addEventListener('click', () => {
      document.getElementById('addCustomerForm')!.style.display = 'none';
      (document.getElementById('newCustomerForm') as HTMLFormElement).reset();
      document.getElementById('formError')!.style.display = 'none';
    });

    document.getElementById('newCustomerForm')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errorEl = document.getElementById('formError')!;
      errorEl.style.display = 'none';

      const body = {
        name: (form.elements.namedItem('name') as HTMLInputElement).value,
        email: (form.elements.namedItem('email') as HTMLInputElement).value,
        password: (form.elements.namedItem('password') as HTMLInputElement).value,
      };

      const res = await fetch('/api/admin/customers', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json();
        errorEl.textContent = err.error || 'Hata oluştu';
        errorEl.style.display = 'block';
        return;
      }

      form.reset();
      document.getElementById('addCustomerForm')!.style.display = 'none';
      loadCustomers();
    });
  });
</script>
