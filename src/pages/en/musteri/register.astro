---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Sign Up - Customer Panel';
const description = 'Sign up for the customer panel and access demo presentations.';
const lang = 'en';
---

<BaseLayout lang={lang} title={title} description={description}>
  <div class="customer-auth">
    <div class="container">
      <div class="auth-card">
        <div class="auth-header">
          <h1>Create Your Account</h1>
          <p class="section-label"><span class="label-line"></span>New Account</p>
        </div>

        <form id="registerForm" class="auth-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="John Doe"
            />
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="name@example.com"
            />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="••••••••"
            />
          </div>

          <button type="submit" class="btn btn-primary">Sign Up</button>
        </form>

        <div id="error" class="error-message"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .customer-auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--section-gap, 4rem) 0;
    background-color: var(--color-bg);
  }

  .customer-auth .container {
    max-width: 480px;
  }

  .auth-card {
    background-color: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  .auth-header {
    margin-bottom: 2rem;
  }

  .auth-header h1 {
    font-size: var(--text-h1);
    font-weight: 900;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .section-label {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .label-line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background-color: var(--color-accent);
  }

  .subtitle {
    font-size: var(--text-body);
    color: var(--color-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .auth-form {
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-label);
    letter-spacing: 0.01em;
  }

  input {
    width: 100%;
    padding: 12px 16px;
    background-color: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 200ms ease-out;
  }

  input::placeholder {
    color: var(--color-subtle);
  }

  input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .btn {
    width: 100%;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: #fff;
    font-family: var(--font-label);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.75rem;
    margin-top: 0.5rem;
  }

  .btn-primary:hover {
    background-color: #fff;
    color: #131313;
  }

  .form-footer {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .form-footer a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 200ms ease-out;
  }

  .form-footer a:hover {
    color: #fff;
  }

  .error-message {
    padding: 1rem;
    background-color: rgba(140, 61, 61, 0.2);
    border: 1px solid var(--color-error);
    border-radius: 4px;
    color: #d9a5a5;
    display: none;
    font-size: 0.9rem;
    margin-top: 1.5rem;
  }

  .error-message.show {
    display: block;
  }

  @media (max-width: 640px) {
    .auth-card {
      padding: 1.5rem;
    }

    .auth-header h1 {
      font-size: var(--text-h2);
    }
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  if (!supabaseUrl || !supabaseAnonKey) {
    console.error('Supabase environment variables not found');
  }

  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById('registerForm');
  const errorDiv = document.getElementById('error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = (form.elements.namedItem('name') as HTMLInputElement).value;
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    const password = (form.elements.namedItem('password') as HTMLInputElement).value;

    try {
      const { data, error } = await supabase.auth.signUpWithPassword({
        email,
        password,
      });

      if (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.add('show');
        return;
      }

      // Store name in users table
      await supabase.from('users').insert([{
        id: data.user?.id,
        email,
        name,
      }]);

      localStorage.setItem('token', data.session?.access_token || '');
      localStorage.setItem('user', JSON.stringify({
        id: data.user?.id,
        email: data.user?.email,
      }));
      window.location.href = '/en/musteri/dashboard';
    } catch (err) {
      errorDiv.textContent = 'Error: ' + (err as Error).message;
      errorDiv.classList.add('show');
    }
  });
</script>
