          "id": "GMAIL_CREDENTIAL_ID",
          "name": "Gmail — Detay Multimedya"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }",
        "options": {
          "responseHeaders": {
